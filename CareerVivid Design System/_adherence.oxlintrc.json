{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/icons/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icons/**",
              "components/navigation/**",
              "redesigns/**",
              "ui_kits/app/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|Inter))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|initial|size|tone|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, initial, size, tone, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:purple|green|amber)$/]",
        "message": "<Avatar> tone must be one of 'purple' | 'green' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|dot|pill|bordered|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children, dot, pill, bordered, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|success|warning|danger|info|neutral)$/]",
        "message": "<Badge> tone must be one of 'accent' | 'success' | 'warning' | 'danger' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|children|disabled|fullWidth|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, children, disabled, fullWidth, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|soft|neutral|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'soft' | 'neutral' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|hoverable|padding|radius|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, hoverable, padding, radius, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:product|warm)$/]",
        "message": "<Card> variant must be one of 'product' | 'warm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryFilter'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<CategoryFilter> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CompanyGuideCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:company|role|difficulty|difficultyLabel|topics|toneIndex|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<CompanyGuideCard> doesn't accept that prop. Declared props: company, role, difficulty, difficultyLabel, topics, toneIndex, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CompanyGuideCard'] > JSXAttribute[name.name='difficulty'] > Literal[value!=/^(?:high|medium|low)$/]",
        "message": "<CompanyGuideCard> difficulty must be one of 'high' | 'medium' | 'low'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|className|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconWell'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|size|iconSize|style|key|ref|className|style|children)$/]",
        "message": "<IconWell> doesn't accept that prop. Declared props: icon, tone, size, iconSize, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconWell'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:purple|softPurple|amber|green|rose|blue|neutral)$/]",
        "message": "<IconWell> tone must be one of 'purple' | 'softPurple' | 'amber' | 'green' | 'rose' | 'blue' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|type|height|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, placeholder, value, onChange, type, height, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='JobCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|company|priority|matchScore|prepDone|prepTotal|dueDate|hasUrl|noDescription|onClick|style|key|ref|className|style|children)$/]",
        "message": "<JobCard> doesn't accept that prop. Declared props: title, company, priority, matchScore, prepDone, prepTotal, dueDate, hasUrl, noDescription, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='JobCard'] > JSXAttribute[name.name='priority'] > Literal[value!=/^(?:High|Medium|Low)$/]",
        "message": "<JobCard> priority must be one of 'High' | 'Medium' | 'Low'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|onClose|actions|width|fixed|style|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: title, children, onClose, actions, width, fixed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|height|style|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: placeholder, value, onChange, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarItemDef'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|badge|section|key|ref|className|style|children)$/]",
        "message": "<SidebarItemDef> doesn't accept that prop. Declared props: id, label, icon, badge, section."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|icon|tone|delta|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, icon, tone, delta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:purple|softPurple|amber|green|rose|blue|neutral)$/]",
        "message": "<StatCard> tone must be one of 'purple' | 'softPurple' | 'amber' | 'green' | 'rose' | 'blue' | 'neutral'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
