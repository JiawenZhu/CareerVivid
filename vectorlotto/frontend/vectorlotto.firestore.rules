rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── CareerVivid existing collections ─────────────────────────────────────
    // (Keep your existing rules above this line)

    // ── VectorLotto Collections ───────────────────────────────────────────────

    // Predictions: anyone can create, only author can read theirs
    match /vectorlotto_predictions/{docId} {
      allow create: if true; // anonymous + authenticated
      allow read: if request.auth != null && 
                     (resource.data.userId == request.auth.uid || resource.data.userId == null);
      allow update, delete: if false;
    }

    // User profiles: only the user themselves
    match /vectorlotto_users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Waitlist: anyone can write (email capture), admin-only read
    match /vectorlotto_waitlist/{emailId} {
      allow create, update: if true;
      allow read, delete: if false; // Admin reads via Firebase Console / Admin SDK
    }
  }
}
