# Public Firebase web configuration
#
# These values are embedded in browser code by design. They identify a Firebase
# project; they do not grant IAM, Admin SDK, or server-side access. Restrict the
# corresponding Google API key by application and allowed web origins in GCP.
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Server-only configuration (DO NOT COMMIT REAL VALUES)
#
# Deploy production credentials through Firebase Secret Manager / Cloud Functions
# service identity. Do not place service-account JSON or IAM credentials in this
# file, a browser build, GitHub Actions, or the repository.
# Use Firebase Secrets for production: firebase functions:secrets:set STRIPE_SECRET_KEY
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Bring-your-own-cloud deployments configure their own project and least-
# privilege runtime service account outside this repository.
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=us-west1

# Set to true to use local Firebase Emulator for Storage
VITE_USE_FIREBASE_EMULATOR=true
