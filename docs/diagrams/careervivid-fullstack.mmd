    %% User Layer
    User((User Devices - Browser/Mobile))
    
    %% Frontend Tier
    subgraph Frontend [🌐 Frontend Tier Client-Side]
        direction TB
        React[React 18 UI Framework]
        Vite[Vite Build Tool]
        Tailwind[Tailwind CSS Styling]
        Framer[Framer Motion Animations]
        Zustand[Zustand State Management]
        ReactRouter[React Router DOM]
        
        React -.-> Tailwind
        React -.-> Framer
        React -.-> Zustand
        React -.-> ReactRouter
    end
    
    %% Backend & API Tier
    subgraph Backend [⚡ Backend API Tier Serverless]
        direction TB
        FirebaseHosting[Firebase Hosting - Global CDN]
        CloudFunctions[Firebase Cloud Functions - Node.js/Express]
        FirebaseAuth[Firebase Authentication - SSO/Email]
        RestAPI[RESTful API Endpoints]
        
        FirebaseHosting <--> CloudFunctions
        CloudFunctions <--> FirebaseAuth
        CloudFunctions <--> RestAPI
    end
    
    %% Data Tier
    subgraph Data [💾 Data Tier]
        direction LR
        Firestore[(Cloud Firestore - NoSQL Database)]
        Storage[(Firebase Cloud Storage - Media/Assets)]
    end
    
    %% AI Processing Engine
    subgraph AIEngine [🧠 AI Processing Engine]
        direction TB
        GeminiCore[Google Gemini Pro/Flash API]
        ResumeParser[AI Resume Parser Optimizer]
        DiagramBuilder[Mermaid Diagram Generator]
        ContentOpt[Content Recommendation Engine]
        
        ResumeParser <--> GeminiCore
        DiagramBuilder <--> GeminiCore
        ContentOpt <--> GeminiCore
    end
    
    %% DevOps & CLI
    subgraph Tools [🛠️ Developer Tools CI/CD]
        direction TB
        CLI[CareerVivid CLI - Node.js/Commander]
        GitHub[GitHub Source Code Actions]
        MCP[Cursor/Claude MCP Server]
    end

    %% Interactions
    User ===|HTTPS/WSS| Frontend
    Frontend ===|API Requests| Backend
    
    Backend ==>|Reads/Writes| Data
    Backend ==>|Prompts| AIEngine
    
    CLI -->|Publishes via API| Backend
    MCP -->|Automates via API| Backend
    
    GitHub -.->|CI/CD Deploys| Backend
    GitHub -.->|CI/CD Deploys| Frontend

