%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#0f172a', 'primaryTextColor': '#f8fafc', 'primaryBorderColor': '#334155', 'lineColor': '#64748b', 'secondaryColor': '#1e293b', 'tertiaryColor': '#334155', 'clusterBkg': '#0d1117', 'clusterBorder': '#30363d'}}}%%
flowchart TB
    %% --- Custom Styles ---
    classDef actor fill:#1e1b4b,stroke:#4f46e5,stroke-width:2px,color:#e0e7ff,rx:20px,ry:20px
    classDef cli fill:#0f172a,stroke:#38bdf8,stroke-width:2px,color:#bae6fd,rx:8px,ry:8px
    classDef mcp fill:#172554,stroke:#3b82f6,stroke-width:2px,color:#bfdbfe,rx:8px,ry:8px
    classDef cloud fill:#2e1065,stroke:#a855f7,stroke-width:2px,color:#e9d5ff,rx:8px,ry:8px
    classDef storage fill:#064e3b,stroke:#10b981,stroke-width:2px,color:#a7f3d0,rx:8px,ry:8px
    classDef ui fill:#451a03,stroke:#f59e0b,stroke-width:2px,color:#fde68a,rx:8px,ry:8px
    classDef generic fill:#020617,stroke:#334155,stroke-width:1px,color:#e2e8f0,rx:5px,ry:5px

    %% --- Actors ---
    User([Developer / AI Agent]):::actor

    %% --- Local Environment ---
    subgraph Local["💻 Local Development Environment"]
        MCP["🤖 MCP Server & IDE Context<br/>(Cursor/Claude Desktop)"]:::mcp
        CLI{"⚙️ CareerVivid CLI (cv)"}:::cli
        Config[("🔑 ~/.careervividrc.json<br/>API Key")]:::generic
    end

    %% --- Cloud Infrastructure ---
    subgraph Cloud["☁️ Google Cloud & Firebase"]
        direction TB
        Endpoint(["🌐 POST /api/publish"]):::cloud
        Auth{"🔐 Firebase Auth<br/>Validation"}:::cloud
        Func["⚡ Cloud Functions<br/>Node.js Environment"]:::cloud
    end

    %% --- Data Layer ---
    subgraph Data["💾 Persistent Storage"]
        DB[("🔥 Firestore<br/>(Posts Collection)")]:::storage
    end

    %% --- Client Interface ---
    subgraph Web["📱 Public Presentation"]
        Frontend["🎨 CareerVivid Platform<br/>(React SPA)"]:::ui
    end

    %% --- Flow Connections ---
    User -- "Asks AI to publish" --> MCP
    User -- "Runs cmd manually" --> CLI
    
    MCP -- "Spawns child process\n(stdin/stdout)" --> CLI
    CLI -. "Reads credentials" .-> Config
    
    CLI -- "Sends structured POST\nwith x-api-key header" --> Endpoint
    Endpoint --> Func
    Func -- "Verifies ownership" --> Auth
    Auth -- "Returns validated root UID" --> Func
    
    Func -- "Sanitizes & Inserts docs" --> DB
    DB -. "Real-time sync\n(onSnapshot)" .-> Frontend

    %% Layout tweaks for alignment
    User ~~~ Local
    Local ~~~ Cloud
    Cloud ~~~ Data
    Data ~~~ Web

