  "semanticTokens": {
    "background": {
      "publicPage": "{modes.light.page.background}",
      "publicPageDark": "{modes.dark.page.background}",
      "productPage": "{modes.light.appShell.background}",
      "productPageDark": "{modes.dark.appShell.background}",
