            "text": "#7c5fd6",
            "ring": "#eadfff"
          },
          {
            "background": "#f5f7ff",
            "text": "#5c62d6",
            "ring": "#e0e5ff"
          }
        ]
      },
      "scoreBadge": {
        "high": {
          "background": "#fff1f2",
          "text": "#be123c",
          "ring": "#fecdd3"
        },
        "medium": {
          "background": "#fffbeb",
          "text": "#b45309",
          "ring": "#fde68a"
        },
        "low": {
          "background": "#eef9f2",
          "text": "#15803d",
          "ring": "#cfe8d5"
        }
      },
      "topicChip": {
        "background": "#f3f4f6",
        "text": "#4b5563",
        "hoverBackground": "#f3f2ff",
        "hoverText": "#625bd5"
      },
      "primaryAction": {
        "background": "#eef0ff",
        "hoverBackground": "#e5e7ff",
        "text": "#625bd5",
        "hoverText": "#514ac5",
        "ring": "#dfe2ff"
      },
      "sourceAction": {
        "background": "#ffffff",
        "border": "#e5e7eb",
        "icon": "#9ca3af",
        "hoverIcon": "#625bd5"
      }
    },
    "dashboardStatCard": {
      "background": "#ffffff",
      "border": "#e5e7eb",
      "radius": "16px",
      "title": {
        "fontSize": "11px-12px",
        "fontWeight": "700",
        "color": "#64748b"
      },
      "number": {
        "fontSize": "24px-32px",
        "fontWeight": "800",
        "color": "#111827"
      },
      "iconWell": {
        "size": "32px-40px",
        "radius": "12px",
        "useTintedBackground": true
      }
    },
    "jobPipelineCard": {
      "background": "#ffffff",
      "border": "#e5e7eb",
      "radius": "10px-12px",
      "title": {
        "fontSize": "13px-15px",
        "fontWeight": "700"
      },
      "metadata": {
        "fontSize": "11px-12px",
        "color": "#6b7280"
      },
      "statusColors": "Use small chips and dots only; avoid large saturated blocks."
    },
    "sidebar": {
      "background": "#ffffff",
      "border": "#ececf4",
      "activeItem": {
        "background": "#eef0ff",
        "text": "#625bd5",
        "border": "#dfe2ff"
      },
      "item": {
        "text": "#64748b",
        "hoverText": "#111827",
        "height": "34px-40px"
      },
      "creditMeter": {
        "track": "#e5e7eb",
        "fill": "#625bd5",
        "label": "#111827",
        "muted": "#6b7280"
      }
    },
    "modal": {
      "backdrop": "rgba(17, 24, 39, 0.45)",
      "background": "#ffffff",
      "radius": "18px-24px",
      "shadow": "{semanticTokens.shadow.modal}",
      "border": "#e5e7eb",
      "padding": "24px-32px",
      "heading": {
        "fontSize": "20px-24px",
        "fontWeight": "800"
      }
    },
    "publicLandingSection": {
      "background": "#f7f1e7",
      "grid": "{layout.grid.warmPublicGrid}",
      "eyebrow": {
        "color": "#a97935",
        "fontSize": "12px",
        "fontWeight": "700",
        "letterSpacing": "0.22em",
        "textTransform": "uppercase"
      },
      "heading": {
        "color": "#211b16",
        "fontWeight": "650",
        "letterSpacing": "0"
      },
      "body": {
        "color": "#665a4a",
        "fontWeight": "500",
        "lineHeight": "2rem"
      }
    },
    "chromeExtensionPanel": {
      "defaultThemeBehavior": "Follow system setting unless user chooses light or dark.",
      "background": "#f8f8fb",
      "surface": "#ffffff",
      "border": "#ececf4",
      "accent": "#625bd5",
      "typography": "Compact job-pipeline typography",
      "themeControl": {
        "visibleButton": "One visible theme button",
        "expandedChoices": [
          "system",
          "light",
          "dark"
        ],
        "interaction": "Hover or focus menu must remain clickable while pointer moves from trigger to menu."
      }
    }
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "normal": "200ms",
      "slow": "320ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "emphasized": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "rules": [
      "Use motion to clarify state changes, not decorate.",
      "Hover lift should stay subtle: about -2px.",
      "Loading and streaming states should be calm and readable.",
      "Respect reduced motion preferences when adding new animation."
    ]
  },
  "accessibility": {
    "contrastTargets": {
      "bodyText": "WCAG AA",
      "smallText": "WCAG AA wherever practical",
      "focusIndicator": "Visible against light and dark surfaces"
    },
    "focus": {
      "alwaysVisibleForKeyboard": true,
      "minimumOutlineWidth": "2px",
      "minimumOutlineOffset": "2px"
    },
    "hitTargets": {
      "minimum": "32px",
      "preferred": "40px-44px for primary controls"
    },
    "textOverflow": {
      "buttons": "No clipping; wrap or shorten labels.",
      "cards": "Truncate repeated-item titles only when the full value is available through context or tooltip.",
      "mobile": "Check all major cards and sidebars at narrow widths."
    },
    "themeQA": [
      "Verify light mode.",
      "Verify dark mode.",
      "Verify system theme behavior.",
      "Verify visible focus states.",
      "Verify muted label contrast.",
      "Verify hover menus remain clickable."
    ]
  },
  "implementationGuidance": {
    "tailwindPatterns": {
      "primaryButton": "bg-[#625bd5] text-white hover:bg-[#514ac5]",
      "softPurpleButton": "bg-[#eef0ff] text-[#625bd5] ring-1 ring-[#dfe2ff] hover:bg-[#e5e7ff]",
      "activeCategoryFilter": "bg-gray-950 text-white dark:bg-gray-100 dark:text-gray-950",
      "warmCard": "cv-warm-card",
      "warmEyebrow": "cv-warm-eyebrow",
      "warmGrid": "cv-warm-grid"
    },
    "cssClasses": {
