    },
    "categoryFilter": {
      "usage": "Interview company guide category filters",
      "active": {
        "background": "#030712",
        "text": "#ffffff",
        "shadow": "0 1px 2px rgba(16, 24, 40, 0.08)"
      },
      "inactive": {
