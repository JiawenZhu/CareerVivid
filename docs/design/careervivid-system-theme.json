    "text": {
      "heading": "#211b16",
      "headingProduct": "#111827",
      "body": "#665a4a",
      "bodyProduct": "#64748b",
      "muted": "#6b7280",
      "subtle": "#9ca3af",
      "inverse": "#ffffff",
      "accent": "#625bd5"
    },
    "border": {
      "warm": "#e4d3bc",
      "product": "#e5e7eb",
      "subtle": "#ececf4",
      "accent": "#dfdcff",
      "focus": "#8d88e6"
    },
    "shadow": {
      "card": "0 1px 2px rgba(16, 24, 40, 0.05)",
      "cardHover": "0 8px 24px rgba(98, 91, 213, 0.08)",
      "modal": "0 24px 70px rgba(17, 24, 39, 0.24)",
      "warmCard": "0 1px 2px rgba(139, 90, 22, 0.05)",
      "inputFocus": "0 1px 2px rgba(16, 24, 40, 0.05), 0 4px 14px rgba(16, 24, 40, 0.08)"
    },
    "status": {
      "success": {
        "background": "#eef9f2",
        "text": "#15803d",
        "border": "#cfe8d5"
      },
      "warning": {
        "background": "#fffbeb",
        "text": "#b45309",
        "border": "#fde68a"
      },
      "danger": {
        "background": "#fff1f2",
        "text": "#be123c",
        "border": "#fecdd3"
      },
      "info": {
        "background": "#eff6ff",
        "text": "#2563eb",
        "border": "#dbeafe"
      },
      "accent": {
        "background": "#f3f2ff",
        "text": "#625bd5",
        "border": "#dfdcff"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "body": "Inter, sans-serif",
      "heading": "Plus Jakarta Sans, sans-serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
    },
    "letterSpacing": {
      "default": "0",
      "compact": "0",
      "eyebrow": "0.22em",
      "badge": "0.08em"
    },
    "scale": {
      "pageTitle": {
        "fontSize": "24px-32px",
        "fontWeight": "700-800",
        "lineHeight": "1.05-1.15",
        "usage": "Dashboard titles, public page hero titles, primary workspace headings"
      },
      "sectionTitle": {
        "fontSize": "16px-22px",
        "fontWeight": "650-750",
        "lineHeight": "1.2-1.3",
        "usage": "Workspace modules, landing sections, settings panels"
      },
      "cardTitle": {
        "fontSize": "13px-15px",
        "fontWeight": "700",
        "lineHeight": "1.25-1.35",
        "usage": "Job cards, interview company cards, resume cards"
      },
      "body": {
        "fontSize": "12px-14px",
        "fontWeight": "500",
        "lineHeight": "1.45-1.75",
        "usage": "Descriptions, helper copy, card summaries"
      },
      "metadata": {
        "fontSize": "10px-12px",
        "fontWeight": "600",
        "lineHeight": "1.2-1.4",
        "usage": "Counts, dates, file metadata, usage summaries"
      },
      "badge": {
        "fontSize": "10px-11px",
        "fontWeight": "700",
        "lineHeight": "1",
        "usage": "Plan chips, state chips, filter labels, compact status"
      }
    }
  },
  "layout": {
    "spacingScale": {
      "0": "0",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px"
    },
    "radius": {
      "controlSmall": "6px",
      "control": "8px",
      "input": "16px",
      "card": "12px",
      "largeCard": "16px",
      "extensionCard": "16px-20px",
      "pill": "999px"
    },
    "borderWidth": {
      "default": "1px",
      "focus": "2px",
      "neverHeavyUnless": "Use thick borders only for focused inputs or intentional editor outlines."
    },
    "containers": {
      "publicPageMaxWidth": "1120px-1280px",
      "dashboardShell": "Full-height product workspace with sidebar plus scrollable content",
      "compactPanel": "Use dense spacing, stable icon buttons, and predictable rows"
    },
    "grid": {
      "warmPublicGrid": {
        "backgroundSize": "64px 64px",
        "lineWeight": "1px",
        "intent": "Subtle editorial structure, never decorative noise"
      },
      "cardGrid": {
        "minColumnWidth": "260px",
        "gap": "12px-24px",
        "intent": "Scanable repeated work items"
      }
    }
  },
  "components": {
    "button": {
      "base": {
        "height": "36px-44px",
        "radius": "8px-16px depending on surrounding UI",
        "fontSize": "12px-14px",
        "fontWeight": "650-700",
        "gap": "6px-8px",
        "iconSize": "16px-18px"
      },
      "primary": {
        "background": "#625bd5",
        "hoverBackground": "#514ac5",
        "text": "#ffffff",
        "shadow": "soft, low contrast"
      },
      "softPurple": {
        "background": "#eef0ff",
        "hoverBackground": "#e5e7ff",
        "text": "#625bd5",
        "border": "#dfe2ff",
        "usage": "Interview guide CTAs, secondary primary actions, selected helpful actions"
      },
      "neutral": {
        "background": "#ffffff",
        "hoverBackground": "#f8f8fb",
        "text": "#374151",
        "border": "#e5e7eb"
      },
      "danger": {
        "background": "#fff1f2",
        "hoverBackground": "#ffe4e6",
        "text": "#be123c",
        "border": "#fecdd3",
        "usage": "Sparse destructive actions only"
      }
    },
    "input": {
      "search": {
        "height": "46px-52px",
        "radius": "16px",
        "background": "rgba(249, 250, 251, 0.8)",
        "focusedBackground": "#ffffff",
        "border": "#e5e7eb",
        "focusedBorder": "#9ca3af",
        "placeholder": "#9ca3af",
        "text": "#111827",
        "icon": "#9ca3af",
        "focusedIcon": "#374151",
        "shadowOnFocus": "{semanticTokens.shadow.inputFocus}",
        "example": "Company guide search bar"
      },
      "textField": {
        "height": "42px-52px",
        "radius": "8px-16px",
        "background": "#ffffff",
        "border": "#d1d5db",
        "focusRing": "#625bd5"
      }
    },
    "card": {
      "base": {
        "background": "#ffffff",
        "border": "#e5e7eb",
        "radius": "12px",
        "padding": "16px-24px",
        "shadow": "{semanticTokens.shadow.card}"
      },
      "hover": {
        "translateY": "-2px",
        "background": "#fbfbff",
        "border": "#dfdcff",
        "shadow": "{semanticTokens.shadow.cardHover}"
      },
      "warmPublic": {
        "background": "rgba(255, 250, 241, 0.88)",
        "border": "#e4d3bc",
        "radius": "12px",
        "shadow": "{semanticTokens.shadow.warmCard}"
      },
      "rules": [
        "Do not place decorative cards inside other decorative cards.",
        "Use cards for repeated items, modals, or framed tools.",
        "Use full-width sections or unframed layouts for page structure."
      ]
    },
    "badge": {
      "base": {
        "radius": "999px",
        "padding": "2px 8px",
        "fontSize": "10px-11px",
        "fontWeight": "700",
        "lineHeight": "1"
      },
      "accent": {
        "background": "#f3f2ff",
        "text": "#625bd5",
        "border": "#dfdcff"
      },
      "success": {
        "background": "#eef9f2",
        "text": "#15803d",
        "border": "#cfe8d5"
      },
      "warning": {
        "background": "#fffbeb",
        "text": "#b45309",
        "border": "#fde68a"
      }
    },
    "segmentedControl": {
      "container": {
        "background": "#f3f4f6",
        "radius": "8px",
        "padding": "4px"
      },
      "item": {
        "height": "34px",
        "radius": "6px",
        "inactiveText": "#4b5563",
        "activeBackground": "#ffffff",
        "activeText": "#625bd5",
        "activeShadow": "0 1px 2px rgba(16, 24, 40, 0.06)"
