{
  "$schema": "https://careervivid.app/schemas/design-system-theme.schema.json",
  "name": "CareerVivid System Theme",
  "slug": "careervivid-system-theme",
  "version": "2026-07-03",
  "status": "source-documentation",
  "description": "Detailed design theme reference for CareerVivid web, dashboard, interview, onboarding, public pages, and extension surfaces.",
  "sourceFiles": [
    "src/index.css",
    "src/pages/InterviewStudio.tsx",
    "src/components/JobTracker/KanbanBoard.tsx",
    "src/pages/JobTrackerPage.tsx",
    "src/extension-ui/layout/ExtensionLayout.tsx",
    "src/extension-ui/pages/ExtensionHome.tsx",
    "src/extension-ui/components/ExtensionHeader.tsx"
  ],
  "designPrinciples": [
    "CareerVivid should feel warm, useful, calm, and job-search focused.",
    "The product is a career workspace, not a flashy AI toy.",
    "Use warm paper and near-white backgrounds as the default visual base.",
    "Use CareerVivid purple as a controlled accent for primary actions, selected states, and focus cues.",
    "Use muted dashboard-inspired status colors in small badges, icon wells, and progress indicators.",
    "Favor compact readable typography, thin borders, soft shadows, and stable action sizes.",
    "Avoid one-note purple, saturated gradients, dark slate dominance, beige-only pages, decorative orbs, and generic AI marketing visuals."
  ],
  "personality": {
    "productFeel": "Warm professional workspace",
    "keywords": [
      "calm",
      "organized",
      "practical",
      "trustworthy",
      "job-search focused",
      "editorial",
      "scanable"
    ],
    "copyTone": {
      "style": "Direct, warm, and practical",
      "preferred": [
        "Save to tracker",
        "Tailor resume",
        "Start mock interview",
        "Open pipeline",
        "Improve next signal",
        "Practice from real company guides"
      ],
      "avoid": [
        "Revolutionary AI",
        "Magic career unlock",
        "Overlong in-app feature explanations",
        "All-caps primary labels outside tiny badges"
      ]
    }
  },
