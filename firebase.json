{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/auth",
        "destination": "/signin",
        "type": 301
      },
      {
        "source": "/login",
        "destination": "/signin",
        "type": 301
      },
      {
        "source": "/register",
        "destination": "/signup",
        "type": 301
      },
      {
        "source": "/support",
        "destination": "/contact",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          }
        ]
      },
      {
        "source": "**/*.@(eot|otf|ttf|ttc|woff|font.css)",
        "headers": [
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          }
        ]
      },
      {
        "source": "/assets/main.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "regex": "^/(?:$|[^.]*$)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/app.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/sitemap.xml",
        "function": "generateSitemap",
        "region": "us-west1"
      },
      {
        "source": "/community",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/community/post/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/shared/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/portfolio/*/edit/**",
        "destination": "/app.html"
      },
      {
        "source": "/portfolio/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/whiteboard/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/zh/shared/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/es/shared/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/zh/community",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/zh/community/post/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/es/community",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/es/community/post/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/zh/demo",
        "destination": "/app.html"
      },
      {
        "source": "/es/demo",
        "destination": "/app.html"
      },
      {
        "source": "/_next/static/**",
        "destination": "/nextjs/_next/static/:splat"
      },
      {
        "source": "/_next/**",
        "destination": "/nextjs/_next/:splat"
      },
      {
        "source": "/",
        "destination": "/nextjs/index.html"
      },
      {
        "source": "/product",
        "destination": "/nextjs/product.html"
      },
      {
        "source": "/pricing",
        "destination": "/nextjs/pricing.html"
      },
      {
        "source": "/contact",
        "destination": "/nextjs/contact.html"
      },
      {
        "source": "/privacy",
        "destination": "/nextjs/privacy.html"
      },
      {
        "source": "/terms",
        "destination": "/nextjs/terms.html"
      },
      {
        "source": "/partners",
        "destination": "/nextjs/partners.html"
      },
      {
        "source": "/partners/academic",
        "destination": "/nextjs/partners/academic.html"
      },
      {
        "source": "/partners/agency",
        "destination": "/nextjs/partners/agency.html"
      },
      {
        "source": "/partners/business",
        "destination": "/nextjs/partners/business.html"
      },
      {
        "source": "/partners/hiring",
        "destination": "/nextjs/partners/hiring.html"
      },
      {
        "source": "/partners/students",
        "destination": "/nextjs/partners/students.html"
      },
      {
        "source": "/blog",
        "destination": "/nextjs/blog.html"
      },
      {
        "source": "/blog/ai-job-search-workspace",
        "destination": "/nextjs/blog/ai-job-search-workspace.html"
      },
      {
        "source": "/blog/ai-resume-builder-job-tracker",
        "destination": "/nextjs/blog/ai-resume-builder-job-tracker.html"
      },
      {
        "source": "/blog/chrome-extension-job-autofill",
        "destination": "/nextjs/blog/chrome-extension-job-autofill.html"
      },
      {
        "source": "/topic/ai-native-developer-portfolios",
        "destination": "/nextjs/topic/ai-native-developer-portfolios.html"
      },
      {
        "source": "/topic/vibe-coding-platform",
        "destination": "/nextjs/topic/vibe-coding-platform.html"
      },
      {
        "source": "/zh/pricing",
        "destination": "/nextjs/zh/pricing.html"
      },
      {
        "source": "/zh/contact",
        "destination": "/nextjs/zh/contact.html"
      },
      {
        "source": "/zh/signin",
        "destination": "/nextjs/zh/signin.html"
      },
      {
        "source": "/zh/signup",
        "destination": "/nextjs/zh/signup.html"
      },
      {
        "source": "/zh/blog",
        "destination": "/nextjs/zh/blog.html"
      },
      {
        "source": "/es/pricing",
        "destination": "/nextjs/es/pricing.html"
      },
      {
        "source": "/es/contact",
        "destination": "/nextjs/es/contact.html"
      },
      {
        "source": "/es/signin",
        "destination": "/nextjs/es/signin.html"
      },
      {
        "source": "/es/signup",
        "destination": "/nextjs/es/signup.html"
      },
      {
        "source": "/es/blog",
        "destination": "/nextjs/es/blog.html"
      },
      {
        "source": "/zh",
        "destination": "/nextjs/zh.html"
      },
      {
        "source": "/zh/",
        "destination": "/nextjs/zh.html"
      },
      {
        "source": "/es",
        "destination": "/nextjs/es.html"
      },
      {
        "source": "/es/",
        "destination": "/nextjs/es.html"
      },
      {
        "source": "/j/*",
        "destination": "/nextjs/j/demo.html"
      },
      {
        "source": "/j/*/*",
        "destination": "/nextjs/j/demo/sample.html"
      },
      {
        "source": "/api/publish",
        "function": "publishPost",
        "region": "us-west1"
      },
      {
        "source": "/api/portfolio/init",
        "function": "initPortfolio",
        "region": "us-west1"
      },
      {
        "source": "/api/portfolio/projects",
        "function": "updatePortfolioProjects",
        "region": "us-west1"
      },
      {
        "source": "/api/portfolio/hero",
        "function": "updatePortfolioHero",
        "region": "us-west1"
      },
      {
        "source": "/api/portfolio/assets",
        "function": "uploadPortfolioAsset",
        "region": "us-west1"
      },
      {
        "source": "/api/public/resume/**",
        "function": "publicResumeApi",
        "region": "us-west1"
      },
      {
        "source": "**",
        "destination": "/app.html"
      }
    ],
    "maxVersionRetained": 5
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" install --install-links",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.4"
  },
  "emulators": {
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },
  "dataconnect": {
    "source": "dataconnect"
  }
}
