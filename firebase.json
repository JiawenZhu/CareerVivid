{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/auth",
        "destination": "/signin",
        "type": 301
      },
      {
        "source": "/login",
        "destination": "/signin",
        "type": 301
      },
      {
        "source": "/register",
        "destination": "/signup",
        "type": 301
      },
      {
        "source": "/support",
        "destination": "/contact",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          }
        ]
      },
      {
        "source": "**/*.@(eot|otf|ttf|ttc|woff|font.css)",
        "headers": [
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/_next/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/workbox-*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/manifest.webmanifest",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "regex": "^/(?:$|[^.]*$)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/sitemap.xml",
        "function": "generateSitemap",
        "region": "us-west1"
      },
      {
        "source": "/community",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/community/post/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/shared/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/portfolio/*/edit/**",
        "destination": "/index.html"
      },
      {
        "source": "/portfolio/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/whiteboard/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/zh/shared/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/es/shared/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/zh/community",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/zh/community/post/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/es/community",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/es/community/post/**",
        "function": "renderSeoContent",
        "region": "us-west1"
      },
      {
        "source": "/_next/static/**",
        "destination": "/nextjs/_next/static/:splat"
      },
      {
        "source": "/_next/**",
        "destination": "/nextjs/_next/:splat"
      },
      {
        "regex": "^/(de|es|fr|ja|ko|zh)/(about|blog|contact|pricing|privacy|signin|signup|terms)/?$",
        "destination": "/nextjs/:1/:2.html"
      },
      {
        "regex": "^/(de|es|fr|ja|ko|zh)/?$",
        "destination": "/nextjs/:1.html"
      },
      {
        "source": "/j/*",
        "destination": "/nextjs/j/demo.html"
      },
      {
        "source": "/j/*/*",
        "destination": "/nextjs/j/demo/sample.html"
      },
      {
        "source": "/api/publish",
        "function": "publishPost",
        "region": "us-west1"
      },
      {
        "source": "/api/portfolio/init",
        "function": "initPortfolio",
        "region": "us-west1"
      },
      {
        "source": "/api/portfolio/projects",
        "function": "updatePortfolioProjects",
        "region": "us-west1"
      },
      {
        "source": "/api/portfolio/hero",
        "function": "updatePortfolioHero",
        "region": "us-west1"
      },
      {
        "source": "/api/portfolio/assets",
        "function": "uploadPortfolioAsset",
        "region": "us-west1"
      },
      {
        "source": "/api/public/resume/**",
        "function": "publicResumeApi",
        "region": "us-west1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "maxVersionRetained": 5
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" install --install-links",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.4"
  },
  "emulators": {
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },
  "dataconnect": {
    "source": "dataconnect"
  }
}
